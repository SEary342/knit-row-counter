# This file is for local development secrets.
# It should be added to .gitignore and not committed to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knit_db

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend Admin Fallback & Secret Key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SECRET_KEY=supersecretkey

# Keycloak Client Secret (from realm export)
KEYCLOAK_CLIENT_SECRET=dev-secret-key